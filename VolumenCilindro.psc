Algoritmo VolumenCilindro
		Definir radio, altura, volumen Como Real
		Definir P Como Real
		
		P <- 3.1416
		
		Escribir "Ingrese el radio:"
		Leer radio
		
		Escribir "Ingrese la altura:"
		Leer altura
		
		volumen <- pi * radio^2 * altura
		
		Escribir "El volumen del cilindro es: ", volumen
FinAlgoritmo	
