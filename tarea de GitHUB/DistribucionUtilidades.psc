Algoritmo DistribucionUtilidades
		Definir utilidades, socioA, socioB, reserva Como Real
		
		Escribir "Ingrese el monto total de utilidades:"
		Leer utilidades
		
		socioA <- utilidades * 0.45
		socioB <- utilidades * 0.30
		reserva <- utilidades * 0.25
		
		Escribir "Monto para Socio A: ", socioA
		Escribir "Monto para Socio B: ", socioB
		Escribir "Monto para Reserva Operativa: ", reserva
FinAlgoritmo
